{
  "name": "wechat-yearbook",
  "version": "0.2.1",
  "private": true,
  "description": "本地优先的微信年度数据分析桌面应用",
  "author": "WeChat Yearbook contributors",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test tests/*.test.js",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:packaged": "node scripts/verify-packaged.mjs",
    "check": "npm test && npm run verify:release && npm run build",
    "pack:dir": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish=never",
    "dist:win": "npm run build && electron-builder --win nsis zip --publish=never"
  },
  "dependencies": {
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@electron/asar": "3.4.1",
    "@electron/fuses": "2.1.3",
    "@vitejs/plugin-react": "6.0.4",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "plist": "3.1.0",
    "vite": "8.1.5"
  },
  "build": {
    "appId": "cn.serkon.wechatyearbook",
    "productName": "微信年轮",
    "asar": true,
    "afterPack": "scripts/after-pack.cjs",
    "electronFuses": {
      "resetAdHocDarwinSignature": true,
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "grantFileProtocolExtraPrivileges": false
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "WeChat-Yearbook-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "identity": null,
      "icon": "build/icon.png",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "build/icon.png",
      "target": ["nsis", "zip"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
